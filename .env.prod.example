# =============================================================================
# Vetra Production Environment Variables
# Copy to .env and fill in real values on the EC2 instance
# =============================================================================

# PostgreSQL
POSTGRES_USER=vetra
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=vetra

# Keycloak
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# GitHub Container Registry PAT (read:packages)
GHCR_TOKEN=CHANGE_ME_GITHUB_PAT
